        "iqr = q3 - q1\n",
        "\n",
        "# Assimetria e Curtose\n",
        "assimetria = stats.skew(va1)\n",
        "curtose = stats.kurtosis(va1)\n",
        "\n",
        "# Resumo Estatístico (usando Pandas)\n",
