        "\n",
        "import numpy as np\n",
        "from scipy.stats import norm\n",
        "from scipy import stats\n",
        "import matplotlib.pyplot as plt\n",
        "import pandas as pd  \n",
        "\n",
        "dados = pd.read_csv('2025-2-gaal-lista-notas.csv')\n",
        "insc = len(dados['CPF']) \n",
        "\n",
        "print('## 1ª Verificação {-}')\n",
        "\n",
        "va1 = dados['VA1'].replace('ausente', np.nan).str.replace(',', '.').astype(float).dropna().to_numpy()\n",
        "N1=len(va1)\n",
        "\n",
        "print('Compareceram à 1ª verificação ','**'+str(N1)+'**',' alunos, de um total de',' **'+str(insc)+'**',' inscritos, isto é, ',round(N1/insc*100,2),'%.')\n",
